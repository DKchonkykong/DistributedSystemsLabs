<Window x:Class="GrpcClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GrpcClient"
        mc:Ignorable="d"
        Title="CalculatorClient" Height="200" Width="420">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="120" />
            <ColumnDefinition Width="20" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="120" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,6,0" Text="Value A" />
        <TextBox x:Name="ValueATb" Grid.Row="0" Grid.Column="1" Height="24" />

        <TextBlock Grid.Row="0" Grid.Column="3" VerticalAlignment="Center" Margin="0,0,6,0" Text="Value B" />
        <TextBox x:Name="ValueBTb" Grid.Row="0" Grid.Column="4" Height="24" />

        <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="5" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,8">
            <Button Width="80" Margin="4,0" Content="Add" Click="Button_Click" />
            <Button Width="80" Margin="4,0" Content="Multiply" Click="Button_Click_1" />
            <Button Width="80" Margin="4,0" Content="Divide" Click="Button_Click_2" />
        </StackPanel>

        <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,6,0" Text="Response" />
        <TextBox x:Name="ResponseValueTb" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="4" Height="24" />
    </Grid>
</Window>